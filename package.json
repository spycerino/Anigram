{
  "name": "anigram",
  "version": "0.1.0",
  "description": "Discord bot for anime watch-groups, powered by AniList.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "tsc -p . && node -e \"require('fs').cpSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "deploy-commands": "tsx src/discord/deploy-commands.ts",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "graphql-request": "^7.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
